APP_ENV=development
APP_BASE_URL=http://localhost:8000
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-this-long-password
SECRET_KEY=change-this-64-char-random-secret
POSTGRES_PASSWORD=change-this-database-password
DATABASE_URL=postgresql+psycopg://setadinfo:${POSTGRES_PASSWORD}@db:5432/setadinfo
REDIS_URL=redis://redis:6379/0
SETAD_BASE_URL=https://gw.setadiran.ir/api/centralboard
SETAD_HTTP_TIMEOUT=15
SETAD_RETRY_ATTEMPTS=3
SETAD_RETRY_DELAY_SECONDS=0.6
SETAD_CACHE_TTL_SECONDS=60
SETAD_STALE_CACHE_TTL_SECONDS=86400
SETAD_PAGE_SIZE=50
SETAD_MAX_PAGES_PER_RUN=20
SETAD_MIN_INTERVAL_MINUTES=15
RUBIKA_BOT_TOKEN=
RUBIKA_DEFAULT_CHAT_ID=
